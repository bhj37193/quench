# Upstream provider — OpenAI (default) or Anthropic
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-your-key-here

# For Anthropic: set UPSTREAM_PROVIDER=anthropic and use your Anthropic key
# UPSTREAM_PROVIDER=anthropic
# UPSTREAM_BASE_URL=https://api.anthropic.com
# UPSTREAM_API_KEY=sk-ant-your-key-here

SIMILARITY_THRESHOLD=0.82
TEMP_CACHE_MAX=0.3
QDRANT_URL=:memory:

# Embedder: local (default, no API key needed) or openai
EMBEDDER=local
# EMBEDDER=openai
# OPENAI_EMBED_API_KEY=sk-your-openai-key-here
